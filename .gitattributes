# Set default behavior to automatically normalize line endings
* text=auto

# Enforce Unix LF line endings for source code, configs, and documentation
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Keep Windows PowerShell scripts using CRLF
*.ps1 text eol=crlf

# Explicitly mark binary files to prevent Git from modifying them
*.png binary
*.ico binary
*.ttf binary
